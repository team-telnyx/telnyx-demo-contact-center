{
  "name": "nextjs-contact-center",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3001 --turbo",
    "dev:https": "next dev --port 3001 --experimental-https --turbo",
    "build": "NEXT_PUBLIC_API_URL=https://contactcenter.telnyx.solutions/api next build",
    "start": "next start --port 3001",
    "lint": "eslint",
    "pages:build": "NEXT_PUBLIC_API_URL=https://contactcenter.telnyx.solutions/api npx @opennextjs/cloudflare build",
    "preview": "npm run pages:build && wrangler dev",
    "deploy": "NEXT_PUBLIC_API_URL=https://contactcenter.telnyx.solutions/api npx @opennextjs/cloudflare deploy"
  },
  "dependencies": {
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.14.6",
    "@mui/material": "^5.14.6",
    "@telnyx/react-client": "^1.0.2",
    "@telnyx/webrtc": "^2.22.15",
    "axios": "^1.6.0",
    "bootstrap": "^5.3.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.3.1",
    "js-sha256": "^0.9.0",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.548.0",
    "next": "15.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-draggable": "^4.4.6",
    "semantic-ui-css": "^2.5.0",
    "semantic-ui-react": "^2.1.4",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@opennextjs/cloudflare": "^1.17.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^9",
    "eslint-config-next": "15.5.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^3.80.0"
  }
}