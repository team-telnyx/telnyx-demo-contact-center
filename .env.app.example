# Server Configuration
PORT=3000
NODE_ENV=development

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=contact_center
DB_USER=root
DB_PASSWORD=your_database_password
DB_DIALECT=mysql

# Authentication
JWT_SECRET=your_jwt_secret_min_32_chars_here_change_me
ENCRYPTION_KEY=your_64_char_hex_encryption_key_for_aes256_change_me_now_please

# Telnyx API
TELNYX_API_KEY=KEYyour_telnyx_api_key_here
TELNYX_CONNECTION_ID=your_telnyx_connection_id
TELNYX_API_URL=https://api.telnyx.com/v2

# CORS
CORS_ORIGINS=https://localhost:3001,https://your-domain.com

# TLS/SSL (optional for development)
TLS_KEY_PATH=/etc/letsencrypt/live/your-domain/privkey.pem
TLS_CERT_PATH=/etc/letsencrypt/live/your-domain/fullchain.pem
