{
    "name": "telnyx-demo-contact-center",
    "version": "4.0.0",
    "private": true,
    "workspaces": [
        "client",
        "server"
    ],
    "scripts": {
        "start": "concurrently \"pnpm run start:server\" \"pnpm run start:client\"",
        "dev": "concurrently \"pnpm run dev:server\" \"pnpm run dev:client\"",
        "start:client": "cd client && pnpm start",
        "start:server": "cd server && pnpm start",
        "dev:client": "cd client && pnpm run dev",
        "dev:server": "cd server && pnpm run dev",
        "build": "pnpm run build:client",
        "build:client": "cd client && pnpm run build",
        "test": "concurrently \"pnpm run test:client\" \"pnpm run test:server\"",
        "test:client": "cd client && pnpm test",
        "test:server": "cd server && pnpm test"
    },
    "devDependencies": {
        "concurrently": "^6.5.1"
    },
    "dependencies": {
        "@telnyx/webrtc": "^2.14.0",
        "axios": "^1.6.0",
        "crypto": "^1.0.1",
        "telnyx": "^6.22.1",
        "uuid": "^14.0.0",
        "ws": "^8.13.0"
    }
}
