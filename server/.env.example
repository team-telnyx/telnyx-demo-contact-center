# Database Configuration
DB_HOST=localhost
DB_NAME=contact_center
DB_USER=root
DB_PASSWORD=

# Server Configuration
PORT=3000
NODE_ENV=development

# Security Keys (Generate secure random keys for production)
JWT_SECRET=your-jwt-secret-key-here
ENCRYPTION_SECRET=your-encryption-secret-key-here
SESSION_SECRET=your-session-secret-key-here

# Telnyx API
TELNYX_API=your-telnyx-api-key-here

# App Configuration
APP_HOST=localhost
APP_PORT=3000

# SSL Certificates (for production)
SSL_PRIVATE_KEY_PATH=/etc/letsencrypt/live/telnyx.solutions/privkey.pem
SSL_CERTIFICATE_PATH=/etc/letsencrypt/live/telnyx.solutions/fullchain.pem

# Telnyx Connection ID
TELNYX_CONNECTION_ID=1446442091122001881