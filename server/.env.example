# Database
DB_HOST="localhost"
DB_PORT="5432"
DB_USER="your_db_user"
DB_PASSWORD="your_db_password"
DB_NAME="agent_desktop"

# Webhook Base URL - publicly reachable URL for your backend server
# Telnyx sends call and messaging webhooks to this address
WEBHOOK_BASE_URL="https://your-server.example.com"

# Security
JWT_SECRET="your-jwt-secret-min-32-characters-long-replace-this"
ENCRYPTION_KEY="64-hex-character-encryption-key-for-sip-password-storage-replace"

# Google SSO (optional)
GOOGLE_CLIENT_ID=""

# CORS
CORS_ORIGINS="*"
