# ──────────────────────────────────────────────────────────────────────
# Telnyx Contact Center — Production Environment
# ──────────────────────────────────────────────────────────────────────
# Copy this file to .env in the project root and fill in values:
#   cp .env.production.example .env
# Used by docker-compose to build the production stack.

# ── Database ──────────────────────────────────────────────────────────
DB_PASSWORD=change_me_to_a_strong_password

# ── App ───────────────────────────────────────────────────────────────
APP_PORT=3001

# ── Auth ──────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 48
JWT_SECRET=
JWT_EXPIRES_IN=24h

# ── Encryption ────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=

# ── Telnyx ────────────────────────────────────────────────────────────
TELNYX_API_KEY=
TELNYX_PUBLIC_KEY=
TELNYX_APP_CONNECTION_ID=
TELNYX_SIP_CONNECTION_ID=
TELNYX_SIP_USERNAME=
TELNYX_SIP_PASSWORD=

# ── Public URL (must be HTTPS and reachable by Telnyx for webhooks) ──
# Example: https://cc.your-domain.com
PUBLIC_URL=

# ── Branding ──────────────────────────────────────────────────────────
COMPANY_NAME=Telnyx Contact Center

# ── Feature flags ─────────────────────────────────────────────────────
TELNYX_STT_ENABLED=true
TELNYX_AI_ENABLED=true

# ── Pexels (optional, for Form Builder image search) ────────────────
# Get a free key at https://www.pexels.com/api/
PEXELS_API_KEY=

# ── Redis ─────────────────────────────────────────────────────────────
# Used by Go webhook handler for call state and pub/sub.
# Leave empty to disable Redis integration.
REDIS_URL=

# ── Internal API Key ─────────────────────────────────────────────────
# Shared secret between Go webhook handler and Node.js server.
# Generate: openssl rand -hex 32
INTERNAL_API_KEY=
